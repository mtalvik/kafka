filebeat.inputs:
  - type: filestream
    id: applogs
    paths:
      - /var/log/app/*.log
    parsers:
      - ndjson:
          target: ""
          overwrite_keys: true
          add_error_key: true

processors:
  - drop_fields:
      fields: ["log", "input", "agent", "ecs", "host"]
      ignore_missing: true

output.kafka:
  hosts:
    - "<KAFKA_HOST>:9092"
  topic: logs
  required_acks: 1
  username: "alice"
  password: "changeme"
  sasl.mechanism: "PLAIN"

logging.level: info
logging.to_stderr: true
