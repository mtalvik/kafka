# elastic-stack environment variables (docker-compose interpolation)
#
# Copy to .env and fill in real values.
# .env is gitignored; .env.example is committed.

# Kafka bootstrap server (private IP of kafka host + listener port)
KAFKA_BOOTSTRAP=<KAFKA_HOST_PRIVATE_IP>:9092

# Kafbat UI connects to Kafka as this principal (must be super.user for full
# visibility of ACLs, consumer groups, internal topics).
KAFBAT_KAFKA_USER=admin
KAFBAT_KAFKA_PASS=<KAFBAT_ADMIN_PASSWORD>
